#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Neutral palette (charcoal + soft grays)
BAR_COLOR=0x00000000
ITEM_BG=0xcc2a2d34
TEXT_PRIMARY=0xffe5e7eb
TEXT_MUTED=0xff9ca3af
ACCENT=0xffd1d5db

sketchybar --bar position=top \
                 height=34 \
                 color=$BAR_COLOR \
                 border_color=0x00000000 \
                 padding_left=8 \
                 padding_right=8 \
                 blur_radius=0 \
                 shadow=off

default=(
  updates=when_shown
  icon.font="Hack Nerd Font:Regular:14.0"
     label.font="SF Pro:Semibold:13"
  icon.color=$TEXT_MUTED
  label.color=$TEXT_PRIMARY
  icon.padding_left=6
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=8
  padding_left=3
  padding_right=3
  background.corner_radius=8
  background.height=24
  background.color=$ITEM_BG
  background.drawing=off
)
sketchybar --default "${default[@]}"

# Left side context
sketchybar --add item front_app left \
           --set front_app \
                icon=􀤆 \
       icon.font="SF Pro:Bold:16.0" \
                script="$PLUGIN_DIR/front_app.sh" \
                click_script="open -a \"$(osascript -e 'tell application \"System Events\" to get name of first process whose frontmost is true')\"" \
                icon.color=$ACCENT \
                label.color=$TEXT_PRIMARY \
     label.font="SF Pro:Semibold:13" \
       background.drawing=off \
                background.color=$ITEM_BG \
                background.corner_radius=10 \
                background.height=24 \
                label.padding_right=10 \
                max_chars=36 \
           --subscribe front_app front_app_switched

sketchybar --add item media center \
     --set media icon=􀑪 script="$PLUGIN_DIR/media.sh" update_freq=5 max_chars=44 click_script="$PLUGIN_DIR/media.sh --open" background.drawing=off \
           --subscribe media media_change system_woke

sketchybar --add bracket left_group front_app \
           --set left_group background.color=0x00000000

# Right side system modules
sketchybar --add item wifi right \
           --set wifi icon=􀙇 script="$PLUGIN_DIR/wifi.sh" update_freq=20 click_script="open x-apple.systempreferences:com.apple.Network-Settings.extension" label.drawing=off icon.padding_right=8

sketchybar --add item bluetooth right \
           --set bluetooth icon= script="$PLUGIN_DIR/bluetooth.sh" update_freq=30 click_script="open x-apple.systempreferences:com.apple.BluetoothSettings" label.drawing=off icon.padding_right=8

sketchybar --add item volume right \
           --set volume icon=􀊩 script="$PLUGIN_DIR/volume.sh" update_freq=0 click_script="open x-apple.systempreferences:com.apple.Sound-Settings.extension" label.drawing=off icon.padding_right=10 \
           --subscribe volume volume_change system_woke

sketchybar --add item ram right \
           --set ram icon=􀫦 script="$PLUGIN_DIR/ram.sh" update_freq=5 click_script="open -a 'Activity Monitor'" icon.padding_right=2

sketchybar --add item battery right \
           --set battery icon=􀛨 script="$PLUGIN_DIR/battery.sh" update_freq=120 click_script="open x-apple.systempreferences:com.apple.Battery-Settings.extension" icon.padding_right=2 \
           --subscribe battery system_woke power_source_change

sketchybar --add item clock right \
           --set clock icon=􀐫 script="$PLUGIN_DIR/clock.sh" update_freq=10 click_script="open -a Calendar"

sketchybar --add bracket right_group wifi bluetooth volume ram battery clock \
           --set right_group background.color=0x00000000

sketchybar --update
